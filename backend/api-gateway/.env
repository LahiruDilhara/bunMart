GATEWAY_NAME=bunmart-api-gateway
GATEWAY_TIMEOUT_SECONDS=30

# Per service: PREFIX = path gateway listens on; URL = backend base (can include path).
# Request path after PREFIX is appended to URL. Example: /cart/products/1 -> CART_URL + /products/1
CART_PREFIX=/carts
CART_URL=http://localhost:8082/api/v1
KITCHEN_PREFIX=/kitchens
KITCHEN_URL=http://localhost:8085/api/v1
NOTIFICATION_PREFIX=/notifications
NOTIFICATION_URL=http://localhost:8086/api/v1
ORDER_PREFIX=/orders
ORDER_URL=http://localhost:8083/api/v1
PAYMENT_PREFIX=/payments
PAYMENT_URL=http://localhost:8084/api/v1
PRICING_PREFIX=/pricings
PRICING_URL=http://localhost:8088/api/v1
PRODUCT_PREFIX=/products
PRODUCT_URL=http://localhost:8081/api/v1
REVIEW_PREFIX=/reviews
REVIEW_URL=http://localhost:8089/api/v1
SHIPPING_PREFIX=/shippings
SHIPPING_URL=http://localhost:8087/api/v1
USER_PREFIX=/users
USER_URL=http://localhost:8090/api/v1
