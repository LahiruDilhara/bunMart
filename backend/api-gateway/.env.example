GATEWAY_NAME=bunmart-api-gateway
GATEWAY_TIMEOUT_SECONDS=30

# REST ports: auth (and user profile) 6001, product 6003, cart 6004, order 6005, payment 6006, pricing 6007, kitchen 6008, notification 6009, review 6010, shipping 6011
# Example: /auth/signin -> AUTH_URL + /signin -> http://localhost:6001/api/v1/auth/signin
# /user/* is proxied to userAuthentication (same as auth)

AUTH_PREFIX=/auth
AUTH_URL=http://localhost:6001/api/v1/auth

CART_PREFIX=/cart
CART_URL=http://localhost:6004/api/v1/cart

KITCHEN_PREFIX=/kitchen
KITCHEN_URL=http://localhost:6008/api/v1/kitchen-orders

NOTIFICATION_PREFIX=/notification
NOTIFICATION_URL=http://localhost:6009/api/v1/notifications

ORDER_PREFIX=/order
ORDER_URL=http://localhost:6005/api/v1/orders

PAYMENT_PREFIX=/payment
PAYMENT_URL=http://localhost:6006/api/v1/payments

PRICING_PREFIX=/pricing
PRICING_URL=http://localhost:6007/api/v1/pricing

PRODUCT_PREFIX=/product
PRODUCT_URL=http://localhost:6003/api/v1

REVIEW_PREFIX=/review
REVIEW_URL=http://localhost:6010/api/v1/reviews

SHIPPING_PREFIX=/shipping
SHIPPING_URL=http://localhost:6011/api/v1/shipping

USER_PREFIX=/user
USER_URL=http://localhost:6001/api/v1/users
