GATEWAY_NAME=bunmart-api-gateway
GATEWAY_TIMEOUT_SECONDS=30

# Each service: PREFIX = path on this gateway, URL = backend base URL
# Request to PREFIX/... is proxied to URL + same path.
# Services: cart, kitchen, notification, order, payment, pricing, product, review, shipping, user
CART_PREFIX=/cart
CART_URL=http://localhost:8082
KITCHEN_PREFIX=/kitchen
KITCHEN_URL=http://localhost:8085
NOTIFICATION_PREFIX=/notification
NOTIFICATION_URL=http://localhost:8086
ORDER_PREFIX=/order
ORDER_URL=http://localhost:8083
PAYMENT_PREFIX=/payment
PAYMENT_URL=http://localhost:8084
PRICING_PREFIX=/pricing
PRICING_URL=http://localhost:8088
PRODUCT_PREFIX=/product
PRODUCT_URL=http://localhost:8081
REVIEW_PREFIX=/review
REVIEW_URL=http://localhost:8089
SHIPPING_PREFIX=/shipping
SHIPPING_URL=http://localhost:8087
USER_PREFIX=/user
USER_URL=http://localhost:8090
